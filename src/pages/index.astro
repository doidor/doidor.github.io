---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
---

<Layout title="Tudor Popa">
  <div class="container">
    <header id="header">
      <h1>Tudor Popa</h1>
      <p class="role">Engineering Leader &middot; Prague</p>
    </header>

    <section id="about">
      <p>
        I build software and teams. Currently leading Fluent UI at Microsoft.
        Previously CTO, co-founder, and individual contributor across a range of industries.
        I care about shipping end-to-end, growing engineers, and staying curious - lately about AI and LLMs.
        When I'm not building, I'm playing guitar or bass.
      </p>
    </section>

    <div class="divider"></div>

    <section id="currently">
      <div class="section-label"><i class="fas fa-briefcase"></i> Currently</div>
      <div class="about-grid">
        <div class="about-item">
          <span class="label">Role:</span> Principal Engineering Manager at Microsoft, leading Fluent UI
        </div>
        <div class="about-item">
          <span class="label">Before:</span> CTO, co-founder, IC - building products and teams from scratch
        </div>
        <div class="about-item">
          <span class="label">Also:</span> Musician. Guitar &amp; bass. Occasional YouTube videos.
        </div>
      </div>
    </section>

    <nav id="links">
      <div class="section-label"><i class="fas fa-link"></i> Links</div>
      <ul>
        <Card body="GitHub" href="https://github.com/doidor" title="GitHub" iconClass="fab fa-github" />
        <Card body="LinkedIn" href="https://www.linkedin.com/in/tdrpopa/" title="LinkedIn" iconClass="fab fa-linkedin" />
        <Card body="Medium" href="https://medium.com/@tdr.popa" title="Medium" iconClass="fab fa-medium" />
        <Card
          body="YouTube"
          href="https://www.youtube.com/@doidor"
          title="YouTube"
          iconClass="fab fa-youtube"
        />
        <Card body="Email" href="mailto:tdr.popa@gmail.com" title="Email" iconClass="fas fa-envelope" />
        <Card
          body="Resume"
          href="https://github.com/doidor/resume/blob/master/resume.pdf"
          title="Resume"
          iconClass="fas fa-file-pdf"
        />
      </ul>
    </nav>

    <footer id="footer">
      <span class="copyright">&copy; Tudor Popa</span>
    </footer>
  </div>
</Layout>
